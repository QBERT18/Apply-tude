# Local development MongoDB connection (used when NODE_ENV !== "production")
MONGODB_URI_DEV=mongodb://localhost:27017/applytude

# Session secret for cookie-based authentication.
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-key-here

# Ollama API endpoint.
# Default 11435 matches the containerised ollama-dev service in docker-compose.yaml.
# If you run Ollama natively (Apple/Windows installer, `ollama serve`), change to 11434.
OLLAMA_URL=http://localhost:11435

# Redis cache (default: redis://localhost:6379 for local dev)
REDIS_URL=redis://localhost:6379